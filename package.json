{
  "name": "agents-academy",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Interactive course for building AI agents on Cloudflare. Astro 6 SSR on Workers + React 19 islands.",
  "scripts": {
    "dev": "astro dev --host --port 4321",
    "build": "astro build && node scripts/postbuild.mjs",
    "preview": "pnpm build && wrangler dev",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint:content": "tsx scripts/lint-content.ts",
    "deploy:staging": "astro build && wrangler deploy --env staging",
    "deploy:production": "astro build && wrangler deploy --env production"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.0",
    "@astrojs/react": "^4.3.0",
    "@monaco-editor/react": "^4.6.0",
    "@phosphor-icons/react": "^2.1.7",
    "@tailwindcss/vite": "^4.1.11",
    "@xyflow/react": "^12.3.0",
    "astro": "^5.13.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "motion": "^11.11.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shiki": "^3.0.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.1.11",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250726.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.20.0"
  },
  "packageManager": "pnpm@9.15.9"
}
