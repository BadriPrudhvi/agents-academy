---
import Base from "../../layouts/Base.astro";
import { TRACKS } from "../../lib/content";
import TrackSection from "../../components/curriculum/TrackSection.astro";
---

<Base title="Learn" description="The Agents Academy curriculum.">
  <div class="mx-auto max-w-6xl px-6 py-14">
    <h1 class="text-3xl md:text-4xl">Curriculum</h1>
    <p class="mt-3 max-w-2xl text-foreground-200">
      Eight tracks, from your first agent to production. Start anywhere — lessons list their
      prerequisites. The Foundations and Your-first-agent tracks are complete and interactive; more are on the way.
    </p>

    <div class="mt-10 space-y-12">
      {TRACKS.map((track) => <TrackSection track={track} />)}
    </div>
  </div>
</Base>
