---
import Base from "../../../layouts/Base.astro";
import { getLesson, getTrack } from "../../../lib/content";
import { highlight } from "../../../lib/highlight";
import { slugify } from "../../../lib/content/inline";
import BlockRenderer from "../../../components/content/BlockRenderer.astro";
import TutorPanel from "../../../components/interactive/tutor/TutorPanel.tsx";
import LessonProgress from "../../../components/interactive/LessonProgress.tsx";
import ViewToggle from "../../../components/interactive/ViewToggle.tsx";
import LessonFeedback from "../../../components/interactive/LessonFeedback.tsx";
import { Clock, Target } from "@phosphor-icons/react";

const { track: trackId, lesson: slug } = Astro.params;
const lesson = getLesson(slug ?? "");
const track = getTrack(trackId ?? "");
const nextLesson = lesson?.next ? getLesson(lesson.next.slug) : undefined;

if (!lesson || !track || lesson.trackId !== track.id) {
  return new Response("Lesson not found", { status: 404 });
}

// Pre-highlight static code blocks (SSR).
const codeHtml = new Map<number, string>();
for (let i = 0; i < lesson.blocks.length; i++) {
  const b = lesson.blocks[i];
  if (b.kind === "code") codeHtml.set(i, await highlight(b.code, b.lang));
}

// Table of contents from heading blocks.
const toc = lesson.blocks
  .filter((b): b is Extract<typeof b, { kind: "heading" }> => b.kind === "heading")
  .map((b) => ({ id: b.id ?? slugify(b.text), text: b.text }));
---

<Base title={lesson.title} description={lesson.summary}>
  <article class="mx-auto max-w-6xl px-6 py-12">
    <a href="/learning" class="font-mono text-xs text-text-secondary hover:text-accent-muted">← Curriculum</a>

    {/* Hero */}
    <header class="mt-4 border-b border-border-100 pb-8">
      <span class="font-mono text-xs uppercase tracking-wider" style={`color: var(--color-${track.accent}-100)`}>
        {track.title} · Lesson {lesson.order}
      </span>
      <h1 class="mt-2 text-3xl md:text-4xl">{lesson.title}</h1>
      <p class="mt-3 max-w-2xl text-lg text-foreground-200">{lesson.summary}</p>
      <div class="mt-4 flex flex-wrap items-center justify-between gap-4">
        <div class="flex flex-wrap items-center gap-4 text-sm text-text-secondary">
          <span class="inline-flex items-center gap-1.5"><Clock size={14} /> {lesson.timeEstimateMin} min</span>
          <span class="inline-flex items-center gap-1.5"><Target size={14} /> {lesson.competencies.length} skills</span>
        </div>
        <ViewToggle client:load targetId="lesson-body" />
      </div>
    </header>

    <div class="mt-8 grid gap-10 lg:grid-cols-[1fr_16rem]">
      {/* Body */}
      <div class="min-w-0" id="lesson-body" data-view="concept">
        {/* Why it matters + outcomes — light, no box */}
        <div class="mb-10 border-l-2 border-border-200 pl-4">
          <p class="text-foreground-200"><strong class="text-foreground-100">Why this matters.</strong> {lesson.whyItMatters}</p>
          <p class="mt-3 text-[11px] uppercase tracking-wider text-text-secondary">By the end you can</p>
          <ul class="mt-1.5 list-disc space-y-1 pl-5 text-sm text-foreground-200">
            {lesson.outcomes.map((o) => <li>{o}</li>)}
          </ul>
        </div>

        {lesson.blocks.map((b, i) => (
          <BlockRenderer lesson={lesson} block={b} index={i} codeHtml={codeHtml.get(i)} />
        ))}

        {/* Recap + next */}
        <div class="mt-12 border-t border-border-100 pt-6">
          <h2 class="text-xl">Recap</h2>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-foreground-200">
            {lesson.recap.map((r) => <li>{r}</li>)}
          </ul>
        </div>
        <div class="mt-4 flex flex-wrap items-center gap-3">
          <LessonProgress client:idle slug={lesson.slug} />
          {lesson.next && nextLesson && (
            <a href={`/learning/${nextLesson.trackId}/${nextLesson.slug}`} class="inline-flex items-center gap-2 rounded-md border border-border-100 px-4 py-2.5 text-sm hover:border-accent-100">
              Next: {lesson.next.label} →
            </a>
          )}
        </div>

        <LessonFeedback client:visible lessonSlug={lesson.slug} />
      </div>

      {/* TOC sidebar */}
      <aside class="hidden lg:block">
        <div class="sticky top-20">
          <p class="mb-2 font-mono text-[11px] uppercase tracking-wider text-text-secondary">On this page</p>
          <nav class="space-y-1.5 border-l border-border-100 pl-3 text-sm">
            {toc.map((h) => (
              <a href={`#${h.id}`} class="block text-foreground-200 hover:text-accent-muted">{h.text}</a>
            ))}
          </nav>
          {lesson.prerequisites.length > 0 && (
            <div class="mt-6">
              <p class="mb-2 font-mono text-[11px] uppercase tracking-wider text-text-secondary">Prerequisites</p>
              <ul class="space-y-1 text-sm text-foreground-200">
                {lesson.prerequisites.map((p) => <li>{p}</li>)}
              </ul>
            </div>
          )}
        </div>
      </aside>
    </div>
  </article>

  <TutorPanel client:idle lessonSlug={lesson.slug} />
</Base>

<script>
  /* Role-aware analogies: within each contiguous cluster of "In your world"
     blocks, show only the one matching the selected role; if the role has no
     analogy, fall back to the first in the cluster. Progressive enhancement —
     without JS every analogy shows (the prior behaviour). */
  import { ROLE_KEY } from "../../../lib/roles";

  function applyRoleAnalogies() {
    const body = document.getElementById("lesson-body");
    if (!body) return;
    let current: string | null = null;
    try {
      current = localStorage.getItem(ROLE_KEY);
    } catch {}

    const kids = Array.from(body.children).filter((el): el is HTMLElement => el instanceof HTMLElement);
    for (let i = 0; i < kids.length; ) {
      if (!kids[i].hasAttribute("data-analogy-role")) {
        i++;
        continue;
      }
      const group: HTMLElement[] = [];
      while (i < kids.length && kids[i].hasAttribute("data-analogy-role")) group.push(kids[i++]);
      const chosen = group.find((el) => el.getAttribute("data-analogy-role") === current) ?? group[0];
      for (const el of group) el.toggleAttribute("data-role-hide", el !== chosen);
    }
  }

  applyRoleAnalogies();
  window.addEventListener("aa:role-change", applyRoleAnalogies);
  document.addEventListener("astro:after-swap", applyRoleAnalogies);
</script>
