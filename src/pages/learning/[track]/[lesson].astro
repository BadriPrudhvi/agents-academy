---
import Base from "../../../layouts/Base.astro";
import { getLesson, getTrack } from "../../../lib/content";
import { highlight } from "../../../lib/highlight";
import CodeLab from "../../../components/interactive/code-lab/CodeLab.tsx";
import Quiz from "../../../components/interactive/Quiz.tsx";
import TutorPanel from "../../../components/interactive/tutor/TutorPanel.tsx";
import LessonProgress from "../../../components/interactive/LessonProgress.tsx";
import ViewToggle from "../../../components/interactive/ViewToggle.tsx";
import AgentDiagram from "../../../components/interactive/AgentDiagram.tsx";
import { Clock, Target, ListChecks } from "@phosphor-icons/react";

const { track: trackId, lesson: slug } = Astro.params;
const lesson = getLesson(slug ?? "");
const track = getTrack(trackId ?? "");

if (!lesson || !track || lesson.trackId !== track.id) {
  return new Response("Lesson not found", { status: 404 });
}

// Pre-highlight static code blocks (SSR).
const codeHtml = new Map<number, string>();
for (let i = 0; i < lesson.blocks.length; i++) {
  const b = lesson.blocks[i];
  if (b.kind === "code") codeHtml.set(i, await highlight(b.code, b.lang));
}

// Table of contents from heading blocks.
const toc = lesson.blocks
  .filter((b): b is Extract<typeof b, { kind: "heading" }> => b.kind === "heading")
  .map((b) => ({ id: b.id ?? slugify(b.text), text: b.text }));

function slugify(s: string) {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
}

// Minimal inline formatter: **bold**, `code`, [text](url).
function inline(text: string): string {
  return text
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/`([^`]+)`/g, '<code class="rounded bg-background-300 px-1 py-0.5 text-[0.9em]">$1</code>')
    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a class="text-accent-muted underline" href="$2" target="_blank" rel="noreferrer">$1</a>');
}

const calloutTone: Record<string, string> = {
  note: "border-compute-100 bg-compute-100/5",
  tip: "border-ai-100 bg-ai-200",
  warning: "border-security-100 bg-security-100/5",
};
---

<Base title={lesson.title} description={lesson.summary}>
  <article class="mx-auto max-w-6xl px-6 py-12">
    <a href="/learning" class="font-mono text-xs text-text-secondary hover:text-accent-muted">← Curriculum</a>

    {/* Hero */}
    <header class="mt-4 border-b border-border-100 pb-8">
      <span class="font-mono text-xs uppercase tracking-wider" style={`color: var(--color-${track.accent}-100)`}>
        {track.title} · Lesson {lesson.order}
      </span>
      <h1 class="mt-2 text-3xl md:text-4xl">{lesson.title}</h1>
      <p class="mt-3 max-w-2xl text-lg text-foreground-200">{lesson.summary}</p>
      <div class="mt-4 flex flex-wrap items-center justify-between gap-4">
        <div class="flex flex-wrap items-center gap-4 text-sm text-text-secondary">
          <span class="inline-flex items-center gap-1.5"><Clock size={14} /> {lesson.timeEstimateMin} min</span>
          <span class="inline-flex items-center gap-1.5"><Target size={14} /> {lesson.competencies.length} skills</span>
        </div>
        <ViewToggle client:load targetId="lesson-body" />
      </div>
    </header>

    <div class="mt-8 grid gap-10 lg:grid-cols-[1fr_16rem]">
      {/* Body */}
      <div class="min-w-0" id="lesson-body" data-view="code">
        {/* Why it matters + outcomes */}
        <div class="mb-8 rounded-xl border border-border-100 bg-background-content p-5">
          <p class="text-sm text-foreground-200"><strong>Why this matters.</strong> {lesson.whyItMatters}</p>
          <p class="mt-3 flex items-center gap-1.5 text-[11px] uppercase tracking-wider text-text-secondary">
            <ListChecks size={13} /> By the end you can
          </p>
          <ul class="mt-1.5 list-disc space-y-1 pl-5 text-sm text-foreground-200">
            {lesson.outcomes.map((o) => <li>{o}</li>)}
          </ul>
        </div>

        {lesson.blocks.map((b, i) => (
          <div data-aud={b.audience ?? undefined}>
            {b.kind === "heading" && (
              <h2 id={b.id ?? slugify(b.text)} class="mt-10 scroll-mt-20 text-2xl">{b.text}</h2>
            )}
            {b.kind === "prose" && <p class="mt-4 leading-relaxed text-foreground-200" set:html={inline(b.text)} />}
            {b.kind === "list" && (
              <ul class={`mt-4 space-y-1.5 pl-5 text-foreground-200 ${b.ordered ? "list-decimal" : "list-disc"}`}>
                {b.items.map((it) => <li set:html={inline(it)} />)}
              </ul>
            )}
            {b.kind === "callout" && (
              <div class={`mt-5 rounded-lg border-l-2 px-4 py-3 ${calloutTone[b.tone]}`}>
                {b.title && <p class="text-sm font-medium text-foreground-100">{b.title}</p>}
                <p class="mt-0.5 text-sm text-foreground-200" set:html={inline(b.text)} />
              </div>
            )}
            {b.kind === "analogy" && (
              <div class="mt-5 rounded-lg border border-border-100 bg-background-300 px-4 py-3">
                <p class="font-mono text-[11px] uppercase tracking-wider text-accent-muted">In your world — {b.role}</p>
                <p class="mt-1 text-sm text-foreground-200" set:html={inline(b.text)} />
              </div>
            )}
            {b.kind === "code" && (
              <figure class="mt-5">
                <div class="overflow-x-auto rounded-lg border border-border-100 text-[13px] [&_pre]:m-0 [&_pre]:p-4" set:html={codeHtml.get(i)} />
                {b.caption && <figcaption class="mt-1.5 font-mono text-xs text-text-secondary">{b.caption}</figcaption>}
              </figure>
            )}
            {b.kind === "diagram" && (
              <AgentDiagram client:visible title={b.title} nodes={b.nodes} edges={b.edges} />
            )}
            {b.kind === "codelab" && lesson.labs[b.labId] && (
              <CodeLab
                client:visible
                lessonSlug={lesson.slug}
                labId={lesson.labs[b.labId].id}
                runCmd={lesson.labs[b.labId].runCmd}
                prompt={lesson.labs[b.labId].challenge.prompt}
                files={lesson.labs[b.labId].files.map((f) => ({ path: f.path, language: f.language, contents: f.contents, readOnly: f.readOnly }))}
                checks={lesson.labs[b.labId].challenge.checks.map((c) => ({ id: c.id, describe: c.describe }))}
                solutionHint={lesson.labs[b.labId].challenge.solutionHint}
              />
            )}
            {b.kind === "quiz" && lesson.quizzes[b.quizId] && (
              <Quiz
                client:visible
                question={lesson.quizzes[b.quizId].question}
                options={lesson.quizzes[b.quizId].options}
                answerIndex={lesson.quizzes[b.quizId].answerIndex}
                explanation={lesson.quizzes[b.quizId].explanation}
              />
            )}
          </div>
        ))}

        {/* Recap + next */}
        <div class="mt-12 rounded-xl border border-border-100 bg-background-content p-5">
          <h2 class="text-xl">Recap</h2>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-foreground-200">
            {lesson.recap.map((r) => <li>{r}</li>)}
          </ul>
        </div>
        <div class="mt-4 flex flex-wrap items-center gap-3">
          <LessonProgress client:idle slug={lesson.slug} />
          {lesson.next && getLesson(lesson.next.slug) && (
            <a href={`/learning/${lesson.trackId}/${lesson.next.slug}`} class="inline-flex items-center gap-2 rounded-md border border-border-100 px-4 py-2.5 text-sm hover:border-accent-100">
              Next: {lesson.next.label} →
            </a>
          )}
        </div>
      </div>

      {/* TOC sidebar */}
      <aside class="hidden lg:block">
        <div class="sticky top-20">
          <p class="mb-2 font-mono text-[11px] uppercase tracking-wider text-text-secondary">On this page</p>
          <nav class="space-y-1.5 border-l border-border-100 pl-3 text-sm">
            {toc.map((h) => (
              <a href={`#${h.id}`} class="block text-foreground-200 hover:text-accent-muted">{h.text}</a>
            ))}
          </nav>
          {lesson.prerequisites.length > 0 && (
            <div class="mt-6">
              <p class="mb-2 font-mono text-[11px] uppercase tracking-wider text-text-secondary">Prerequisites</p>
              <ul class="space-y-1 text-sm text-foreground-200">
                {lesson.prerequisites.map((p) => <li>{p}</li>)}
              </ul>
            </div>
          )}
        </div>
      </aside>
    </div>
  </article>

  <TutorPanel client:idle lessonSlug={lesson.slug} />
</Base>
