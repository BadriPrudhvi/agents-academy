---
import { roleIdFromLabel } from "../../lib/roles";
import { inline, slugify } from "../../lib/content/inline";
import type { Block, Lesson } from "../../lib/content/types";
import NodeGraph from "../interactive/NodeGraph.tsx";
import WatchItRun from "../interactive/WatchItRun.tsx";
import AgentRun from "../interactive/AgentRun.tsx";
import StreamingChat from "../interactive/StreamingChat.tsx";
import AgentStudio from "../interactive/AgentStudio.tsx";
import CodeLab from "../interactive/code-lab/CodeLab.tsx";
import Quiz from "../interactive/Quiz.tsx";

interface Props {
  lesson: Lesson;
  block: Block;
  index: number;
  /** Pre-highlighted HTML for `code` blocks (SSR, computed by the page). */
  codeHtml?: string;
}

const { lesson, block: b, index: i, codeHtml } = Astro.props;

const calloutTone: Record<string, string> = {
  note: "border-compute-100 bg-compute-100/5",
  tip: "border-ai-100 bg-ai-200",
  warning: "border-security-100 bg-security-100/5",
};
---

<div
  data-aud={b.audience ?? undefined}
  data-analogy-role={b.kind === "analogy" ? (roleIdFromLabel(b.role) ?? slugify(b.role)) : undefined}
  data-role-hide={b.kind === "analogy" && i > 0 && lesson.blocks[i - 1].kind === "analogy" ? "true" : undefined}
>
  {b.kind === "heading" && (
    <h2 id={b.id ?? slugify(b.text)} class="mt-10 scroll-mt-20 text-2xl">{b.text}</h2>
  )}
  {b.kind === "prose" && <p class="mt-4 leading-relaxed text-foreground-200" set:html={inline(b.text)} />}
  {b.kind === "statement" && (
    <div class="my-10 text-center">
      <p
        class="mx-auto max-w-2xl text-balance text-2xl font-medium leading-tight md:text-3xl [&_strong]:font-medium [&_strong]:text-accent-muted"
        set:html={inline(b.text)}
      />
      {b.sub && <p class="mx-auto mt-3 max-w-xl text-foreground-200" set:html={inline(b.sub)} />}
    </div>
  )}
  {b.kind === "compare" && (
    <div class="my-8 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-border-100 bg-background-200 p-5">
        <p class="mb-3 font-medium text-foreground-100">{b.left.title}</p>
        <ul class="space-y-2 text-sm text-foreground-200">
          {b.left.items.map((it) => (
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-muted">✕</span><span set:html={inline(it)} /></li>
          ))}
        </ul>
      </div>
      <div class="rounded-xl border border-accent-100 bg-background-content p-5">
        <p class="mb-3 font-medium text-foreground-100">{b.right.title}</p>
        <ul class="space-y-2 text-sm text-foreground-200">
          {b.right.items.map((it) => (
            <li class="flex items-start gap-2"><span class="mt-0.5 text-ai-100">✓</span><span set:html={inline(it)} /></li>
          ))}
        </ul>
      </div>
    </div>
  )}
  {b.kind === "list" && (
    <ul class={`mt-4 space-y-1.5 pl-5 text-foreground-200 ${b.ordered ? "list-decimal" : "list-disc"}`}>
      {b.items.map((it) => <li set:html={inline(it)} />)}
    </ul>
  )}
  {b.kind === "callout" && (
    <div class={`mt-5 rounded-lg border-l-2 px-4 py-3 ${calloutTone[b.tone]}`}>
      {b.title && <p class="text-sm font-medium text-foreground-100">{b.title}</p>}
      <p class="mt-0.5 text-sm text-foreground-200" set:html={inline(b.text)} />
    </div>
  )}
  {b.kind === "analogy" && (
    <div class="mt-5 border-l-2 border-accent-100/30 pl-4">
      <p class="font-mono text-[11px] uppercase tracking-wider text-accent-muted">In your world — {b.role}</p>
      <p class="mt-1 text-sm text-foreground-200" set:html={inline(b.text)} />
    </div>
  )}
  {b.kind === "code" && (
    <figure class="mt-5">
      <div class="overflow-x-auto rounded-lg border border-border-100 text-[13px] [&_pre]:m-0 [&_pre]:p-4" set:html={codeHtml} />
      {b.caption && <figcaption class="mt-1.5 font-mono text-xs text-text-secondary">{b.caption}</figcaption>}
    </figure>
  )}
  {b.kind === "diagram" && (
    <NodeGraph client:visible title={b.title} caption={b.caption} nodes={b.nodes} edges={b.edges} />
  )}
  {b.kind === "watch" && lesson.labs[b.labId] && (
    <WatchItRun client:visible lessonSlug={lesson.slug} labId={b.labId} caption={b.caption} />
  )}
  {b.kind === "agentRun" && lesson.agentRuns?.[b.runId] && (
    <AgentRun
      client:visible
      lessonSlug={lesson.slug}
      runId={lesson.agentRuns[b.runId].id}
      intro={lesson.agentRuns[b.runId].intro}
      model={lesson.agentRuns[b.runId].model}
      tools={lesson.agentRuns[b.runId].tools}
      examples={lesson.agentRuns[b.runId].examples}
    />
  )}
  {b.kind === "streamChat" && lesson.streamChats?.[b.chatId] && (
    <StreamingChat
      client:visible
      lessonSlug={lesson.slug}
      chatId={lesson.streamChats[b.chatId].id}
      intro={lesson.streamChats[b.chatId].intro}
      model={lesson.streamChats[b.chatId].model}
      examples={lesson.streamChats[b.chatId].examples}
    />
  )}
  {b.kind === "agentStudio" && lesson.studios?.[b.studioId] && (
    <AgentStudio
      client:visible
      lessonSlug={lesson.slug}
      studioId={lesson.studios[b.studioId].id}
      title={lesson.studios[b.studioId].title}
      intro={lesson.studios[b.studioId].intro}
      toolName={lesson.studios[b.studioId].toolName}
      toolPreview={lesson.studios[b.studioId].toolPreview}
      starterProgram={lesson.studios[b.studioId].starterProgram}
      capabilities={lesson.studios[b.studioId].capabilities}
      goals={lesson.studios[b.studioId].goals.map((g) => ({ id: g.id, label: g.label, program: g.program, chatbotGuess: g.chatbotGuess }))}
      aiEnabled={lesson.studios[b.studioId].aiEnabled}
    />
  )}
  {b.kind === "codelab" && lesson.labs[b.labId] && (
    <CodeLab
      client:visible
      lessonSlug={lesson.slug}
      labId={lesson.labs[b.labId].id}
      runCmd={lesson.labs[b.labId].runCmd}
      prompt={lesson.labs[b.labId].challenge.prompt}
      files={lesson.labs[b.labId].files.map((f) => ({ path: f.path, language: f.language, contents: f.contents, readOnly: f.readOnly }))}
      checks={lesson.labs[b.labId].challenge.checks.map((c) => ({ id: c.id, describe: c.describe }))}
      solutionHint={lesson.labs[b.labId].challenge.solutionHint}
    />
  )}
  {b.kind === "quiz" && lesson.quizzes[b.quizId] && (
    <Quiz
      client:visible
      question={lesson.quizzes[b.quizId].question}
      options={lesson.quizzes[b.quizId].options}
      answerIndex={lesson.quizzes[b.quizId].answerIndex}
      explanation={lesson.quizzes[b.quizId].explanation}
    />
  )}
</div>
